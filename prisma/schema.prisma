generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/jimeng.db"
}

model ApiKey {
  id             String         @id @default(uuid())
  key            String         @unique
  owner          String
  quota          Int?
  used           Int            @default(0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tasks          Task[]
  boundAccountId String?
  boundAccount   JimengAccount? @relation(fields: [boundAccountId], references: [id])

  @@index([boundAccountId])
}

model JimengAccount {
  id            String   @id @default(uuid())
  name          String   @unique
  homeDir       String   @unique
  status        String   @default("IDLE")
  creditBalance Int      @default(0)
  lastChecked   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
  boundApiKeys  ApiKey[]
}

model Task {
  id             String         @id @default(uuid())
  apiKeyId       String
  apiKey         ApiKey         @relation(fields: [apiKeyId], references: [id])
  accountId      String?
  account        JimengAccount? @relation(fields: [accountId], references: [id])
  type           String
  model          String?
  prompt         String
  jimengSubmitId String?
  jimengLogId    String?
  status         String         @default("PENDING")
  resultUrl      String?
  errorMsg       String?
  pollErrorMsg   String?
  queueStatus    String?
  queueIndex     Int?
  queueLength    Int?
  queueWaitSeconds Int?
  progressPercent Int?
  liveStatusRaw  String?
  lastPolledAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([apiKeyId])
  @@index([accountId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, jimengSubmitId])
}
